{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5436;Database=auth_service_db;Username=postgres;Password=postgres"
  },
  "PasswordSettings": {
    "RequiredLength" : 8,
    "RequireDigit" : true,
    "RequireNonAlphanumeric" : true,
    "RequireUppercase" : true,
    "RequireLowercase" : true
  },
  "LockoutSettings": {
    "MaxFailedAccessAttempts" : 5,
    "DefaultLockoutTimeSpan" : "00:05:00"
  },
  "UserSettings": {
    "RequireUniqueEmail" : true,
    "RequireUniqueUserName" : true
  },
  "AllowedHosts": "*"
}
